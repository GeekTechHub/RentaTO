# RENTARD Server — copia a .env y rellena con valores reales
# DATABASE_URL: Postgres connection string (Neon, Supabase, local, etc.)
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# JWT_SECRET: genera con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="cambia-esto-por-un-hex-aleatorio-de-64-chars"

# Puerto (Render/Railway lo asignan automáticamente, ignora en producción)
PORT=3000

# Dominios permitidos por CORS (separados por coma)
ALLOWED_ORIGINS="http://localhost:5173,http://localhost:3000,https://renta-to.vercel.app"

# Entorno (development | production)
NODE_ENV=development

# ── Email (Resend) ── opcional: si falta, los emails se omiten sin romper nada
# API key en https://resend.com (free 100/día)
RESEND_API_KEY=""
# Remitente verificado. Para probar sin dominio: "RentaTO <onboarding@resend.dev>"
MAIL_FROM="RentaTO <onboarding@resend.dev>"
# URL pública del frontend (para los links en los correos)
APP_URL="https://renta-to.vercel.app"

# ── Pagos (PayPal) ── opcional: si falta, el fee de US$1 queda deshabilitado
# Crea una app en https://developer.paypal.com (modo Sandbox primero)
PAYPAL_CLIENT_ID=""
PAYPAL_SECRET=""
# sandbox = pruebas sin dinero real | live = producción
PAYPAL_ENV="sandbox"
