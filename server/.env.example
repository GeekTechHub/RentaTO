# RENTARD Server — copia a .env y rellena con valores reales
# DATABASE_URL: Postgres connection string (Neon, Supabase, local, etc.)
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# JWT_SECRET: genera con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="cambia-esto-por-un-hex-aleatorio-de-64-chars"

# Puerto (Render/Railway lo asignan automáticamente, ignora en producción)
PORT=3000

# Dominios permitidos por CORS (separados por coma)
ALLOWED_ORIGINS="http://localhost:5173,http://localhost:3000,https://renta-to.vercel.app"

# Entorno (development | production)
NODE_ENV=development
